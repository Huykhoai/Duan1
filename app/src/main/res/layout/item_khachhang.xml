<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="5dp"
    >
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/textviewtenkhachhang"
        android:text="Tên khách hàng"
        android:textSize="20dp"
        android:textStyle="bold"
        android:layout_marginTop="5dp"
        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/textviewsdtkhachhang"
        android:text="Số Điện Thoai"
        android:textSize="15dp"
        android:layout_marginTop="10dp"
        android:layout_below="@+id/textviewtenkhachhang"

        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/textviewemailkhachhang"
        android:text="Email"
        android:textSize="15dp"
        android:layout_marginTop="10dp"
        android:layout_below="@+id/textviewsdtkhachhang"

        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/textviewdiachikhachhang"
        android:text="Địa chỉ"
        android:textSize="15dp"
        android:layout_marginTop="10dp"
        android:layout_below="@+id/textviewemailkhachhang"
        />

</RelativeLayout>